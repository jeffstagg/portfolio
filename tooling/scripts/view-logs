#!/bin/bash

# Portfolio Development Environment Log Viewer

# Colors for output
BLUE='\033[0;34m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Configuration
PORTFOLIO_ROOT="$HOME/Portfolio"
LOG_DIR="$PORTFOLIO_ROOT/tooling/logs"

# Check if logs directory exists
if [ ! -d "$LOG_DIR" ]; then
    echo -e "${YELLOW}No logs directory found. Have you run launch-dev yet?${NC}"
    exit 1
fi

# Function to display menu
show_menu() {
    clear
    echo -e "${BLUE}╔════════════════════════════════════════════════════════════╗${NC}"
    echo -e "${BLUE}║                                                            ║${NC}"
    echo -e "${BLUE}║              Portfolio Development Logs                    ║${NC}"
    echo -e "${BLUE}║                                                            ║${NC}"
    echo -e "${BLUE}╚════════════════════════════════════════════════════════════╝${NC}"
    echo ""
    echo -e "${GREEN}Available Logs:${NC}"
    echo ""
    echo "  1) Cosmos DB Emulator"
    echo "  2) Portfolio.DataAccess"
    echo "  3) Portfolio.API"
    echo "  4) Portfolio.React"
    echo "  5) All logs (tail -f all)"
    echo "  6) Clear all logs"
    echo "  0) Exit"
    echo ""
}

# Function to tail log file
tail_log() {
    local log_file=$1
    local service_name=$2
    
    if [ -f "$log_file" ]; then
        echo -e "${GREEN}Tailing $service_name log (Ctrl+C to stop)...${NC}"
        echo ""
        tail -f "$log_file"
    else
        echo -e "${YELLOW}Log file not found: $log_file${NC}"
        echo "Press any key to continue..."
        read -n 1
    fi
}

# Function to tail all logs
tail_all_logs() {
    echo -e "${GREEN}Tailing all logs (Ctrl+C to stop)...${NC}"
    echo ""
    
    if command -v multitail &> /dev/null; then
        multitail \
            -s 4 \
            -l "tail -f $LOG_DIR/cosmosdb.log" \
            -l "tail -f $LOG_DIR/data-access.log" \
            -l "tail -f $LOG_DIR/api.log" \
            -l "tail -f $LOG_DIR/react.log"
    else
        # Fallback if multitail is not available
        tail -f "$LOG_DIR"/*.log
    fi
}

# Function to clear logs
clear_logs() {
    echo -e "${YELLOW}Clearing all logs...${NC}"
    rm -f "$LOG_DIR"/*.log
    echo -e "${GREEN}All logs cleared!${NC}"
    sleep 1
}

# Main loop
while true; do
    show_menu
    read -p "Select an option: " choice
    
    case $choice in
        1)
            tail_log "$LOG_DIR/cosmosdb.log" "Cosmos DB Emulator"
            ;;
        2)
            tail_log "$LOG_DIR/data-access.log" "Portfolio.DataAccess"
            ;;
        3)
            tail_log "$LOG_DIR/api.log" "Portfolio.API"
            ;;
        4)
            tail_log "$LOG_DIR/react.log" "Portfolio.React"
            ;;
        5)
            tail_all_logs
            ;;
        6)
            clear_logs
            ;;
        0)
            echo -e "${GREEN}Goodbye!${NC}"
            exit 0
            ;;
        *)
            echo -e "${YELLOW}Invalid option. Press any key to continue...${NC}"
            read -n 1
            ;;
    esac
done
